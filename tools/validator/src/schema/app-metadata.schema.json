{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiprovenanceprotocol.io/schema/v1.0/app-metadata.schema.json",
  "title": "AI Provenance Protocol Metadata",
  "description": "Schema for APP metadata objects conforming to the AI Provenance Protocol v1.0 specification.",
  "type": "object",
  "required": [
    "app_version",
    "ai_generated",
    "generator",
    "generated_at",
    "generation_id"
  ],
  "properties": {
    "app_version": {
      "type": "string",
      "description": "Protocol version in semver format.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "examples": ["1.0.0"]
    },
    "ai_generated": {
      "type": "boolean",
      "description": "Whether the content was generated or substantially modified by AI."
    },
    "generator": {
      "$ref": "#/$defs/Generator"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation completion."
    },
    "generation_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 uniquely identifying this generation event."
    },
    "inputs": {
      "$ref": "#/$defs/Inputs"
    },
    "review": {
      "$ref": "#/$defs/Review"
    },
    "usage": {
      "$ref": "#/$defs/Usage"
    },
    "verification_uri": {
      "type": "string",
      "format": "uri",
      "description": "Endpoint where this generation can be verified."
    },
    "parent_generation_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID linking to a previous generation event in a provenance chain."
    },
    "content_hash": {
      "type": "string",
      "description": "Hash of the generated content for integrity verification.",
      "pattern": "^(sha256|sha384|sha512):[0-9a-f]+$"
    },
    "extensions": {
      "type": "object",
      "description": "Namespace for domain-specific extensions using reverse-domain keys.",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Generator": {
      "type": "object",
      "description": "Information about the system that produced the content.",
      "required": ["platform", "model"],
      "properties": {
        "platform": {
          "type": "string",
          "description": "Identifier of the platform that orchestrated generation.",
          "minLength": 1
        },
        "platform_version": {
          "type": "string",
          "description": "Version of the platform."
        },
        "model": {
          "type": "string",
          "description": "Identifier of the AI model used (recommended format: provider/model-name).",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "Inputs": {
      "type": "object",
      "description": "Description of inputs used for generation.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "structured", "multimodal", "code", "other"],
          "description": "Category of input."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the inputs."
        },
        "items": {
          "type": "array",
          "description": "List of individual input sources.",
          "items": {
            "$ref": "#/$defs/InputItem"
          }
        },
        "prompt_ref": {
          "type": "string",
          "description": "Identifier or hash of the prompt template used."
        }
      },
      "additionalProperties": false
    },
    "InputItem": {
      "type": "object",
      "description": "A single input source used in generation.",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["text", "image", "data", "code", "audio", "video", "document", "other"],
          "description": "Type of input."
        },
        "ref": {
          "type": "string",
          "description": "Reference to the input (URI, identifier, or field name)."
        },
        "hash": {
          "type": "string",
          "description": "Content hash of the input for integrity.",
          "pattern": "^(sha256|sha384|sha512):[0-9a-f]+$"
        },
        "fields": {
          "type": "array",
          "description": "For data kind: list of field names used.",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "Review": {
      "type": "object",
      "description": "Human review status of the generated content.",
      "required": ["human_reviewed"],
      "properties": {
        "human_reviewed": {
          "type": "boolean",
          "description": "Whether a human has reviewed this content."
        },
        "reviewer_role": {
          "type": "string",
          "description": "Functional role of the reviewer (not PII)."
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of review completion."
        },
        "review_type": {
          "type": "string",
          "enum": [
            "approved_without_changes",
            "edited",
            "rejected",
            "pending"
          ],
          "description": "Nature of the review."
        },
        "review_notes": {
          "type": "string",
          "description": "Free-text notes from the reviewer."
        }
      },
      "additionalProperties": false
    },
    "Usage": {
      "type": "object",
      "description": "Resource consumption for the generation event.",
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of input tokens consumed."
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of output tokens produced."
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Total tokens (input + output)."
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Generation duration in milliseconds."
        }
      },
      "additionalProperties": false
    }
  }
}
